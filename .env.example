# ============================================================
# Amazon Affiliate Configuration
# ============================================================
AMAZON_ASSOCIATE_ID=your-associate-20
AMAZON_MARKETPLACE=www.amazon.co.jp

# PA-API credentials (leave blank to use scraper fallback)
PAAPI_ACCESS_KEY=
PAAPI_SECRET_KEY=
PAAPI_PARTNER_TAG=your-associate-20

# ============================================================
# Claude API
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=4096

# ============================================================
# Article Generation Settings
# ============================================================
ARTICLES_PER_RUN=3
MIN_WORD_COUNT=1500
ARTICLE_TYPES=review,ranking,comparison
DEFAULT_CATEGORY=家電

# ============================================================
# note.com Publishing
# ============================================================
NOTE_EMAIL=your@email.com
NOTE_PASSWORD=your_password
NOTE_DEFAULT_DRAFT=true

# ============================================================
# Storage
# ============================================================
DB_PATH=./data/affiliate_blog.db
LOG_PATH=./logs/affiliate_blog.log

# ============================================================
# Scheduler
# ============================================================
SCHEDULER_TIMEZONE=Asia/Tokyo
DISCOVERY_CRON=0 6 * * *
GENERATION_CRON=0 8 * * *
PUBLISHING_CRON=0 10,14,18 * * *

# ============================================================
# Rate Limiting
# ============================================================
PAAPI_REQUESTS_PER_SECOND=1
SCRAPER_DELAY_SECONDS=4
CLAUDE_REQUESTS_PER_MINUTE=50
